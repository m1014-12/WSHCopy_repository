import React from 'react';
import { render, screen, fireEvent, waitFor } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { BrowserRouter } from 'react-router-dom';
import axios from 'axios';
import ForgotPasswordPage from '../forgetPassword';
// Mock context providers
jest.mock('../../context/ThemeLanguageContext', () => ({
  ThemeLanguageProvider: ({ children }) => <div>{children}</div>,
  useThemeLanguage: () => ({
    language: 'en',
    isDarkMode: false,
    toggleTheme: jest.fn(),
    toggleLanguage: jest.fn(),
  }),
}));

// Mock axios
jest.mock('axios');
const mockedAxios = axios;

// Mock useNavigate
const mockNavigate = jest.fn();
jest.mock('react-router-dom', () => ({
  useNavigate: () => mockNavigate,
  Link: ({ children, to }) => <a href={to}>{children}</a>,
  BrowserRouter: ({ children }) => <div>{children}</div>,
}));

// Mock ThemeLanguageToggles component
jest.mock('../../components/ThemeLanguageToggles', () => {
  return function MockThemeLanguageToggles() {
    return <div data-testid="theme-language-toggles">Theme/Language Toggles</div>;
  };
});

// Test wrapper component
const TestWrapper = ({ children }) => (
  <div>
    {children}
  </div>
);

describe('ForgotPasswordPage', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  it('renders forgot password form correctly', () => {
    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    expect(screen.getByText(/forgot password/i)).toBeInTheDocument();
    expect(screen.getByLabelText(/email/i)).toBeInTheDocument();
    expect(screen.getByRole('button', { name: /send reset link/i })).toBeInTheDocument();
    expect(screen.getByText(/know password/i)).toBeInTheDocument();
    expect(screen.getByText(/login/i)).toBeInTheDocument();
  });

  it('displays validation error when email is empty', async () => {
    const user = userEvent.setup();
    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const submitButton = screen.getByRole('button', { name: /send reset link/i });
    await user.click(submitButton);

    await waitFor(() => {
      expect(screen.getByText(/fill email/i)).toBeInTheDocument();
    });
  });

  it('submits form with valid email', async () => {
    const user = userEvent.setup();
    const mockResponse = {
      data: {
        message: 'Password reset link sent to your email'
      }
    };

    mockedAxios.post.mockResolvedValueOnce(mockResponse);

    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);
    const submitButton = screen.getByRole('button', { name: /send reset link/i });

    await user.type(emailInput, 'test@example.com');
    await user.click(submitButton);

    await waitFor(() => {
      expect(mockedAxios.post).toHaveBeenCalledWith(
        'http://localhost:3001/forgot-password',
        {
          email: 'test@example.com'
        }
      );
    });

    await waitFor(() => {
      expect(screen.getByText(/password reset link sent/i)).toBeInTheDocument();
    });
  });

  it('handles successful password reset request', async () => {
    const user = userEvent.setup();
    const mockResponse = {
      data: {
        message: 'Reset link sent successfully'
      }
    };

    mockedAxios.post.mockResolvedValueOnce(mockResponse);

    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);
    const submitButton = screen.getByRole('button', { name: /send reset link/i });

    await user.type(emailInput, 'user@example.com');
    await user.click(submitButton);

    await waitFor(() => {
      const messageElement = screen.getByText(/reset link sent successfully/i);
      expect(messageElement).toBeInTheDocument();
      expect(messageElement).toHaveClass('success');
    });
  });

  it('handles email not found error', async () => {
    const user = userEvent.setup();
    const mockErrorResponse = {
      data: {
        message: 'Email not found'
      }
    };

    mockedAxios.post.mockResolvedValueOnce(mockErrorResponse);

    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);
    const submitButton = screen.getByRole('button', { name: /send reset link/i });

    await user.type(emailInput, 'nonexistent@example.com');
    await user.click(submitButton);

    await waitFor(() => {
      expect(mockedAxios.post).toHaveBeenCalledWith(
        'http://localhost:3001/forgot-password',
        {
          email: 'nonexistent@example.com'
        }
      );
    });

    await waitFor(() => {
      const messageElement = screen.getByText(/email not found/i);
      expect(messageElement).toBeInTheDocument();
      expect(messageElement).toHaveClass('error');
    });
  });

  it('handles network error', async () => {
    const user = userEvent.setup();
    mockedAxios.post.mockRejectedValueOnce(new Error('Network error'));

    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);
    const submitButton = screen.getByRole('button', { name: /send reset link/i });

    await user.type(emailInput, 'test@example.com');
    await user.click(submitButton);

    await waitFor(() => {
      const messageElement = screen.getByText(/error message/i);
      expect(messageElement).toBeInTheDocument();
      expect(messageElement).toHaveClass('error');
    });
  });

  it('displays error message for invalid email format', async () => {
    const user = userEvent.setup();
    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);
    const submitButton = screen.getByRole('button', { name: /send reset link/i });

    // Type invalid email
    await user.type(emailInput, 'invalid-email');
    await user.click(submitButton);

    // The form should still submit but server will handle validation
    await waitFor(() => {
      expect(mockedAxios.post).toHaveBeenCalledWith(
        'http://localhost:3001/forgot-password',
        {
          email: 'invalid-email'
        }
      );
    });
  });

  it('clears form after successful submission', async () => {
    const user = userEvent.setup();
    const mockResponse = {
      data: {
        message: 'Password reset link sent to your email'
      }
    };

    mockedAxios.post.mockResolvedValueOnce(mockResponse);

    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);
    const submitButton = screen.getByRole('button', { name: /send reset link/i });

    await user.type(emailInput, 'test@example.com');
    await user.click(submitButton);

    await waitFor(() => {
      expect(screen.getByText(/password reset link sent/i)).toBeInTheDocument();
    });

    // Email field should still contain the value (component doesn't clear it)
    expect(emailInput).toHaveValue('test@example.com');
  });

  it('renders navigation links correctly', () => {
    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    expect(screen.getByText(/know password/i)).toBeInTheDocument();
    const loginLink = screen.getByText(/login/i);
    expect(loginLink).toBeInTheDocument();
    expect(loginLink.closest('a')).toHaveAttribute('href', '/login');
  });

  it('renders theme and language toggles', () => {
    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    expect(screen.getByTestId('theme-language-toggles')).toBeInTheDocument();
  });

  it('handles form submission with Enter key', async () => {
    const user = userEvent.setup();
    const mockResponse = {
      data: {
        message: 'Password reset link sent to your email'
      }
    };

    mockedAxios.post.mockResolvedValueOnce(mockResponse);

    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);

    await user.type(emailInput, 'test@example.com');
    await user.keyboard('{Enter}');

    await waitFor(() => {
      expect(mockedAxios.post).toHaveBeenCalledWith(
        'http://localhost:3001/forgot-password',
        {
          email: 'test@example.com'
        }
      );
    });
  });

  it('displays multiple error messages correctly', async () => {
    const user = userEvent.setup();
    const mockErrorResponse = {
      data: {
        message: 'Server error occurred'
      }
    };

    mockedAxios.post.mockResolvedValueOnce(mockErrorResponse);

    render(
      <TestWrapper>
        <ForgotPasswordPage />
      </TestWrapper>
    );

    const emailInput = screen.getByLabelText(/email/i);
    const submitButton = screen.getByRole('button', { name: /send reset link/i });

    await user.type(emailInput, 'test@example.com');
    await user.click(submitButton);

    await waitFor(() => {
      const messageElement = screen.getByText(/server error occurred/i);
      expect(messageElement).toBeInTheDocument();
      expect(messageElement).toHaveClass('error');
    });
  });
});
